APP_NAME=ai-trading-311-webhook
DEBUG_MODE=0
LOCAL_TZ=Europe/Zurich

# --- SECURITY ---
WEBHOOK_SECRET=change-me

# --- GOOGLE SHEETS (Service Account JSON) ---
GOOGLE_CREDS_FILE=keys/service_account.json
SPREADSHEET_ID=your-spreadsheet-id
SHEET_NAME=TradesV2

# --- TELEGRAM ---
TG_TOKEN=your-bot-token
TG_CHAT_ID=your-chat-id
TG_DISABLE_PREVIEW=1
TG_PARSE_MODE=HTML

# --- OPTIONAL ---
FORCE_DECIMALS=5

# --- MULTI-TIMEFRAME ANALYSIS ---
# Set MTF_ENABLED=1 to run 3-TF analysis on ENTRY events.
# Looks for {MTF_DATA_DIR}/{symbol_lower}_5m.csv (e.g. data/xauusd_5m.csv).
# Non-fatal: if CSV missing, webhook still processes normally.
MTF_ENABLED=0
MTF_DATA_DIR=data/
